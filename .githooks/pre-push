#!/usr/bin/env bash
# EAOS pre-push hook — blocks `git push` unless the repo validates.
# Enable once with:  git config core.hooksPath .githooks   (or: ./scripts/install-hooks.sh)
set -uo pipefail
cd "$(git rev-parse --show-toplevel)"

printf "\033[1;36m[pre-push]\033[0m validating before push...\n"

fail=0
bash -n setup.sh || fail=1
[ -f scripts/eaos-doctor.sh ] && { bash -n scripts/eaos-doctor.sh || fail=1; }
[ -f scripts/push-to-github.sh ] && { bash -n scripts/push-to-github.sh || fail=1; }
if command -v python3 >/dev/null 2>&1; then
  python3 scripts/validate-eaos.py || fail=1
else
  printf "\033[1;33m[pre-push]\033[0m python3 not found — skipping structural validation\n"
fi

if [ "$fail" -ne 0 ]; then
  printf "\033[1;31m[pre-push] validation failed — push aborted.\033[0m Fix the errors above, then push again.\n"
  printf "            (To bypass in an emergency: git push --no-verify)\n"
  exit 1
fi
printf "\033[0;32m[pre-push] validation passed — pushing.\033[0m\n"
exit 0
